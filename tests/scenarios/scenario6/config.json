{
  "advanced": { "advanced_mode": false, "debounce_seconds": 2 },
  "common": { "name": "Home", "horizon_preset": "7_days" },
  "integration_type": "hub",
  "minor_version": 4,
  "record_forecasts": true,
  "tiers": {
    "tier_1_count": 5,
    "tier_1_duration": 1,
    "tier_2_count": 11,
    "tier_2_duration": 5,
    "tier_3_count": 46,
    "tier_3_duration": 30,
    "tier_4_count": 48,
    "tier_4_duration": 60
  },
  "update_interval_minutes": 5,
  "version": 1,
  "participants": {
    "Battery": {
      "name": "Battery",
      "element_type": "battery",
      "connection": { "type": "connection_target", "value": "Inverter" },
      "efficiency": {
        "efficiency_source_target": { "type": "constant", "value": 98.0 },
        "efficiency_target_source": { "type": "constant", "value": 98.0 }
      },
      "limits": {
        "max_charge_percentage": { "type": "constant", "value": 100.0 },
        "min_charge_percentage": { "type": "constant", "value": 5.0 }
      },
      "overcharge": {},
      "partitioning": {},
      "power_limits": {
        "max_power_source_target": { "type": "entity", "value": ["sensor.sigen_plant_ess_rated_discharging_power"] },
        "max_power_target_source": { "type": "entity", "value": ["sensor.sigen_plant_ess_rated_charging_power"] }
      },
      "pricing": {},
      "storage": {
        "capacity": { "type": "entity", "value": ["sensor.sigen_plant_rated_energy_capacity"] },
        "initial_charge_percentage": { "type": "entity", "value": ["sensor.sigen_plant_battery_state_of_charge"] }
      },
      "undercharge": {}
    },
    "Grid": {
      "name": "Grid",
      "element_type": "grid",
      "connection": { "type": "connection_target", "value": "Switchboard" },
      "power_limits": {
        "max_power_source_target": { "type": "constant", "value": 55.0 },
        "max_power_target_source": { "type": "constant", "value": 30.0 }
      },
      "pricing": {
        "price_source_target": { "type": "entity", "value": ["sensor.amber_express_home_general_price"] },
        "price_target_source": { "type": "entity", "value": ["sensor.amber_express_home_feed_in_price"] }
      }
    },
    "Inverter": {
      "name": "Inverter",
      "element_type": "inverter",
      "connection": { "type": "connection_target", "value": "Switchboard" },
      "efficiency": {},
      "power_limits": {
        "max_power_source_target": { "type": "entity", "value": ["sensor.sigen_plant_max_active_power"] },
        "max_power_target_source": { "type": "entity", "value": ["sensor.sigen_plant_max_active_power"] }
      }
    },
    "Load": {
      "name": "Load",
      "element_type": "load",
      "connection": { "type": "connection_target", "value": "Switchboard" },
      "curtailment": {},
      "forecast": {
        "forecast": {
          "type": "entity",
          "value": ["sensor.sigen_plant_consumed_power_forecast", "sensor.sigen_plant_consumed_power"]
        }
      }
    },
    "Policies": {
      "name": "Policies",
      "element_type": "policy",
      "rules": [
        {
          "name": "Battery Wear",
          "enabled": { "type": "constant", "value": true },
          "price": { "type": "constant", "value": 0.01 },
          "source": ["Battery"]
        },
        {
          "name": "Battery min sell",
          "enabled": { "type": "constant", "value": true },
          "price": { "type": "constant", "value": 0.04 },
          "source": ["Battery"],
          "target": ["Grid"]
        },
        {
          "name": "Solar Minimum Sell",
          "enabled": { "type": "constant", "value": true },
          "price": { "type": "constant", "value": 0.02 },
          "source": ["Solar"],
          "target": ["Grid"]
        }
      ]
    },
    "Solar": {
      "name": "Solar",
      "element_type": "solar",
      "connection": { "type": "connection_target", "value": "Inverter" },
      "curtailment": { "curtailment": { "type": "constant", "value": true } },
      "forecast": {
        "forecast": {
          "type": "entity",
          "value": [
            "sensor.energy_production_d3_east",
            "sensor.energy_production_d4_east",
            "sensor.energy_production_d5_east",
            "sensor.energy_production_d6_east",
            "sensor.energy_production_d7_east",
            "sensor.energy_production_d2_east",
            "sensor.energy_production_today_east",
            "sensor.energy_production_tomorrow_east",
            "sensor.energy_production_d3_north",
            "sensor.energy_production_d4_north",
            "sensor.energy_production_d5_north",
            "sensor.energy_production_d6_north",
            "sensor.energy_production_d7_north",
            "sensor.energy_production_d2_north",
            "sensor.energy_production_today_north",
            "sensor.energy_production_tomorrow_north",
            "sensor.energy_production_d3_south",
            "sensor.energy_production_d4_south",
            "sensor.energy_production_d5_south",
            "sensor.energy_production_d6_south",
            "sensor.energy_production_d7_south",
            "sensor.energy_production_d2_south",
            "sensor.energy_production_today_south",
            "sensor.energy_production_tomorrow_south",
            "sensor.energy_production_d3_west",
            "sensor.energy_production_d4_west",
            "sensor.energy_production_d5_west",
            "sensor.energy_production_d6_west",
            "sensor.energy_production_d7_west",
            "sensor.energy_production_d2_west",
            "sensor.energy_production_today_west",
            "sensor.energy_production_tomorrow_west",
            "sensor.sigen_plant_pv_power"
          ]
        }
      }
    },
    "Switchboard": { "name": "Switchboard", "element_type": "node", "role": { "is_sink": false, "is_source": false } }
  }
}
